{
  "entities": {
    "Hub": {
      "title": "Hub",
      "description": "A travel hub, starting point, or sightseeing endpoint",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique hub slug ID" },
        "name": { "type": "string", "description": "Hub name" },
        "type": { "type": "string", "enum": ["main_hub", "sightseeing_hub", "sub_hub"] }
      },
      "required": ["id", "name", "type"]
    },
    "Route": {
      "title": "Route",
      "description": "A direct route from one hub to another",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Route ID" },
        "fromHubId": { "type": "string" },
        "toHubId": { "type": "string" },
        "path": { "type": "array", "description": "Stops on the route" },
        "type": { "type": "string", "enum": ["Direct", "Indirect"] },
        "fareMin": { "type": "number" },
        "fareMax": { "type": "number" },
        "timeMin": { "type": "number" },
        "timeMax": { "type": "number" },
        "verified": { "type": "boolean" },
        "distance": { "type": "number" },
        "lastUpdated": { "type": "string" }
      },
      "required": ["id", "fromHubId", "toHubId", "path", "type", "fareMin", "fareMax", "timeMin", "timeMax", "verified", "lastUpdated"]
    },
    "Destination": {
      "title": "Destination",
      "description": "A gorgeous hill station destination",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "tourismType": { "type": "string" },
        "bestSeason": { "type": "string" },
        "image": { "type": "string" },
        "gallery": { "type": "array" },
        "coverImage": { "type": "string" },
        "coverPrompt": { "type": "string" },
        "coverStatus": { "type": "string", "enum": ["pending", "generated", "failed", "manual"] }
      },
      "required": ["id", "name", "description", "tourismType", "bestSeason", "image", "gallery"]
    },
    "Attraction": {
      "title": "Attraction",
      "description": "Sightseeing attraction in a travel destination",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "destinationId": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "gallery": { "type": "array" },
        "coverImage": { "type": "string" },
        "coverPrompt": { "type": "string" },
        "coverStatus": { "type": "string", "enum": ["pending", "generated", "failed", "manual"] }
      },
      "required": ["id", "name", "category", "destinationId", "description", "image", "gallery"]
    },
    "Homestay": {
      "title": "Homestay",
      "description": "Cozy hill homestay for booking/inquiries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "destinationId": { "type": "string" },
        "priceMin": { "type": "number" },
        "priceMax": { "type": "number" },
        "contact": { "type": "string" },
        "amenities": { "type": "array" },
        "images": { "type": "array" }
      },
      "required": ["id", "name", "destinationId", "priceMin", "priceMax", "contact", "amenities", "images"]
    },
    "ImageItem": {
      "title": "ImageItem",
      "description": "Scenic image contribution or official photo asset",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "destinationId": { "type": "string" },
        "attractionId": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "caption": { "type": "string" },
        "altText": { "type": "string" },
        "userId": { "type": "string" },
        "rejectionReason": { "type": "string" }
      },
      "required": ["id", "url", "uploadedBy", "uploadDate", "status", "caption", "altText"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "A user-submitted data addition, correction, or photo upload",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["add_route", "correct_route", "report_missing_route", "add_attraction", "add_homestay", "upload_photo"] },
        "details": { "type": "object" },
        "contributorName": { "type": "string" },
        "contributorMobile": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "type", "details", "contributorName", "contributorMobile", "status", "createdAt"]
    },
    "TripLead": {
      "title": "TripLead",
      "description": "Travel planning lead request submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "destination": { "type": "string" },
        "travelDate": { "type": "string" },
        "budget": { "type": "number" },
        "numTravellers": { "type": "number" },
        "services": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "mobile", "destination", "travelDate", "budget", "numTravellers", "services", "createdAt"]
    },
    "CarLead": {
      "title": "CarLead",
      "description": "Car hire / rental referral lead request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "travelDate": { "type": "string" },
        "passengers": { "type": "number" },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "pickup", "destination", "travelDate", "passengers", "name", "mobile", "status", "createdAt"]
    },
    "SearchEvent": {
      "title": "SearchEvent",
      "description": "Analytics search event tracking details",
      "type": "object",
      "properties": {
        "searchId": { "type": "string" },
        "searchQuery": { "type": "string" },
        "routeId": { "type": "string" },
        "destinationId": { "type": "string" },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "sourceDestination": { "type": "string" },
        "destination": { "type": "string" },
        "searchDate": { "type": "string" },
        "searchTime": { "type": "string" },
        "deviceType": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "hasResults": { "type": "boolean" }
      },
      "required": ["searchId", "timestamp", "sessionId", "searchDate", "searchTime"]
    },
    "InteractionEvent": {
      "title": "InteractionEvent",
      "description": "Consumer product view or click tracking telemetry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["destination_view", "image_view", "route_click"] },
        "entityId": { "type": "string" },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" },
        "sessionId": { "type": "string" }
      },
      "required": ["id", "type", "entityId", "timestamp", "sessionId"]
    },
    "UserAnalyticsEvent": {
      "title": "UserAnalyticsEvent",
      "description": "Visitor analytics and activity tracking event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["route_search", "destination_visit", "attraction_visit"] },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "source": { "type": "string" },
        "destination": { "type": "string" },
        "timestamp": { "type": "string" },
        "count": { "type": "number" }
      },
      "required": ["id", "type", "name", "timestamp", "count"]
    },
    "Driver": {
      "title": "Driver",
      "description": "Registered local vehicle / partner driver for hire",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "whatsapp": { "type": "string" },
        "vehicleType": { "type": "string" },
        "vehicleName": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "serviceAreas": { "type": "string" },
        "pricingPerDay": { "type": "number" },
        "licenseNumber": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] }
      },
      "required": ["id", "name", "mobile", "whatsapp", "vehicleType", "vehicleName", "vehicleNumber", "serviceAreas", "pricingPerDay", "createdAt", "status"]
    },
    "UserRole": {
      "title": "UserRole",
      "description": "Legacy administrator or moderator role definitions for backoffice authorization",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User email address as unique key" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "moderator"] },
        "status": { "type": "string", "enum": ["active", "restricted"] },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "email", "role", "status", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "Administrative and customer user account details with access roles and security info",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique combination value, e.g. email or UUID" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "passwordHash": { "type": "string", "description": "Secure password hashed value" },
        "role": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "disabled"] },
        "emailVerified": { "type": "boolean" },
        "customPermissions": { "type": "array", "description": "Explicit individual override permissions list" },
        "createdAt": { "type": "string" },
        "mobile": { "type": "string" },
        "businessName": { "type": "string" },
        "businessType": { "type": "string" },
        "partnerLocation": { "type": "string" },
        "partnerMobile": { "type": "string" },
        "partnerStatus": { "type": "string" },
        "partnerDocuments": { "type": "string" },
        "contributorRegion": { "type": "string" },
        "contributorReason": { "type": "string" },
        "contributorExperience": { "type": "string" },
        "contributorStatus": { "type": "string" }
      },
      "required": ["id", "email", "name", "passwordHash", "role", "status", "emailVerified", "customPermissions", "createdAt"]
    },
    "Role": {
      "title": "Role",
      "description": "Predefined RBAC role categories",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "System role key, e.g. super_admin" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "description"]
    },
    "Permission": {
      "title": "Permission",
      "description": "Granular functional system access permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "E.g. manage_users, manage_content" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "description"]
    },
    "RolePermission": {
      "title": "RolePermission",
      "description": "Mapping from standard roles to default permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roleId": { "type": "string" },
        "permissionId": { "type": "string" }
      },
      "required": ["id", "roleId", "permissionId"]
    },
    "UserPermission": {
      "title": "UserPermission",
      "description": "Explicit assignment of individual permissions to users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "permissionId": { "type": "string" }
      },
      "required": ["id", "userId", "permissionId"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Immutable security log tracing admin actions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string" },
        "ipAddress": { "type": "string" }
      },
      "required": ["id", "userId", "email", "action", "details", "timestamp"]
    },
    "Like": {
      "title": "Like",
      "description": "Represents a user's single like of a destination, attraction, or photo",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Formed as userId_contentId" },
        "userId": { "type": "string" },
        "contentId": { "type": "string" },
        "contentType": { "type": "string", "enum": ["destination", "attraction", "photo"] },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "contentId", "contentType", "timestamp"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A user-submitted comment on a destination or attraction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "contentId": { "type": "string" },
        "contentType": { "type": "string", "enum": ["destination", "attraction"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "contentId", "contentType", "text", "timestamp"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "General system/travel notifications and alerts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["custom", "destination_added", "attraction_added", "homestay_added", "route_alert", "travel_advisory"] },
        "status": { "type": "string", "enum": ["draft", "pending", "published", "rejected"] },
        "imageUrl": { "type": "string" },
        "destinationId": { "type": "string" },
        "attractionId": { "type": "string" },
        "homestayId": { "type": "string" },
        "routeName": { "type": "string" },
        "routeStatus": { "type": "string", "enum": ["Open", "Closed", "Restricted", "Partially Open"] },
        "createdAt": { "type": "string" },
        "approvedAt": { "type": "string" },
        "approvedBy": { "type": "string" },
        "isPushNotification": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["normal", "important", "urgent"] }
      },
      "required": ["id", "title", "message", "type", "status", "createdAt", "isPushNotification", "priority"]
    },
    "ClaimRequest": {
      "title": "ClaimRequest",
      "description": "A claim request from a potential homestay owner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homestayId": { "type": "string" },
        "partnerUserId": { "type": "string" },
        "ownerName": { "type": "string" },
        "mobile": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "ownershipProof": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "adminRemarks": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "homestayId", "partnerUserId", "ownerName", "mobile", "whatsapp", "email", "message", "status", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "An inquiry sent by a traveler for a certain homestay",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homestayId": { "type": "string" },
        "userName": { "type": "string" },
        "userMobile": { "type": "string" },
        "userEmail": { "type": "string" },
        "travelDate": { "type": "string" },
        "numberOfGuests": { "type": "number" },
        "message": { "type": "string" },
        "inquiryStatus": { "type": "string", "enum": ["new", "contacted", "converted", "closed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "homestayId", "userName", "userMobile", "userEmail", "travelDate", "numberOfGuests", "message", "inquiryStatus", "createdAt"]
    },
    "OwnershipHistory": {
      "title": "OwnershipHistory",
      "description": "A log of ownership transitions for homestays",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homestayId": { "type": "string" },
        "previousOwnerId": { "type": "string" },
        "newOwnerId": { "type": "string" },
        "approvedByAdminId": { "type": "string" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "homestayId", "approvedByAdminId", "timestamp"]
    },
    "PendingUpdate": {
      "title": "PendingUpdate",
      "description": "A pending details update by a partner before admin approval",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homestayId": { "type": "string" },
        "partnerUserId": { "type": "string" },
        "updateData": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "homestayId", "partnerUserId", "updateData", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user-submitted review / feedback about the HillyTrip platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userMobile": { "type": "string" },
        "rating": { "type": "number" },
        "category": { "type": "string", "enum": ["General", "Routes & Maps", "Destinations", "Homestays", "Cabs / Drivers", "App Experience", "Other"] },
        "comment": { "type": "string" },
        "wouldRecommend": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Approved", "Pending", "Flagged", "Addressed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userName", "userEmail", "rating", "category", "comment", "wouldRecommend", "status", "createdAt"]
    }
  },
  "firestore": {
    "user_roles": {
      "schema": "UserRole",
      "description": "Legacy User access permissions list for the administration control desk"
    },
    "users": {
      "schema": "User",
      "description": "Admin and moderator account records with state details"
    },
    "roles": {
      "schema": "Role",
      "description": "Available systemic roles definitions"
    },
    "permissions": {
      "schema": "Permission",
      "description": "Full roster of fine-grain permission nodes"
    },
    "role_permissions": {
      "schema": "RolePermission",
      "description": "Default permission maps for default roles"
    },
    "user_permissions": {
      "schema": "UserPermission",
      "description": "Granular user override records"
    },
    "audit_logs": {
      "schema": "AuditLog",
      "description": "Immutable logs tracing critical system events"
    },
    "hubs": {
      "schema": "Hub",
      "description": "Master list of trip routers and hill transit hubs"
    },
    "routes": {
      "schema": "Route",
      "description": "All route paths between nodes"
    },
    "destinations": {
      "schema": "Destination",
      "description": "Gorgeous destinations for exploration details"
    },
    "attractions": {
      "schema": "Attraction",
      "description": "Tourist attractions nested under destinations"
    },
    "homestays": {
      "schema": "Homestay",
      "description": "Verified local cozy homestay options"
    },
    "images": {
      "schema": "ImageItem",
      "description": "Verified photographic display assets"
    },
    "contributions": {
      "schema": "Contribution",
      "description": "Crowdsourced addition ideas awaiting moderation review"
    },
    "tripLeads": {
      "schema": "TripLead",
      "description": "Personalized trip coordination inquiries"
    },
    "carLeads": {
      "schema": "CarLead",
      "description": "Rental and hire driver service requests"
    },
    "searches": {
      "schema": "SearchEvent",
      "description": "Analytics telemetry tracker log of queries"
    },
    "interactions": {
      "schema": "InteractionEvent",
      "description": "Telemetry action logs from explorer interactions"
    },
    "user_analytics": {
      "schema": "UserAnalyticsEvent",
      "description": "Visitor analytics and activity events"
    },
    "drivers": {
      "schema": "Driver",
      "description": "Local partner drivers and private hired car fleet listings"
    },
    "likes": {
      "schema": "Like",
      "description": "User like records for destinations, attractions, and photos"
    },
    "comments": {
      "schema": "Comment",
      "description": "User discussions and comments under destinations and attractions"
    },
    "notifications": {
      "schema": "AppNotification",
      "description": "System-wide travel alerts and notifications"
    },
    "claim_requests": {
      "schema": "ClaimRequest",
      "description": "Ownership claim requests for homestays"
    },
    "inquiries": {
      "schema": "Inquiry",
      "description": "Direct inquiries from travelers for specific homestays"
    },
    "ownership_history": {
      "schema": "OwnershipHistory",
      "description": "Ownership history tracks transfers of homestays"
    },
    "pending_updates": {
      "schema": "PendingUpdate",
      "description": "Pending corrections/updates to homestay listings before admin approval"
    },
    "reviews": {
      "schema": "Review",
      "description": "User reviews and feedback submitted regarding the HillyTrip platform"
    }
  }
}
