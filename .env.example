# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AI_GEOCODING_PHASE: Operational phase for location geocoding services.
# 1 = Local Caching & Smart Parent-Destination Fallbacks (Optimized for free tiers, zero API calls, ultra-stable)
# 2 = On-Demand Dynamic AI Generation (Lazy loads single-record additions)
# 3 = Automated Proactive Bulk Processing
AI_GEOCODING_PHASE=1

# AI_COVER_PHASE: Operational phase for cover prompt & cover image creation.
# 1 = Templated Prompts & Curated Unsplash Cover Maps (Recommended for standard operations)
# 2 = On-Demand Gemini Prompt & Image Generation
# 3 = Fully Automated Background Backlog Creator
AI_COVER_PHASE=1

# SUPABASE CONFIGURATION:
# If specified, hillytrip will automatically synchronize all primary and analytics data 
# with your Supabase PostgreSQL database in real-time, using local file-based offline fallback cache.
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-or-service-role-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Client-side Supabase environment variables (required for Netlify production builds)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-or-service-role-key"

# Backend API endpoint URL (for frontend-only hosting such as Netlify)
VITE_BACKEND_URL="https://hillytrip-api-930292453548.asia-south1.run.app"

# SMTP EMAIL NOTIFICATION CONFIGURATION:
# If configured, HillyTrip will send real email notifications to both customers and partners.
# If unconfigured, emails will gracefully log to the server console instead.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false" # "true" for port 465, "false" for 587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM_NAME="HillyTrip Desk"
SMTP_FROM_EMAIL="noreply@hillytrip.com"

# OPENWEATHERMAP CONFIGURATION:
# If specified, HillyTrip will use this API key to fetch high-fidelity 5-day weather forecasts.
# If omitted, HillyTrip will gracefully fallback to the free Open-Meteo API.
VITE_OPENWEATHERMAP_API_KEY=""

# WHATSAPP SUPPORT:
# The phone number used for direct floating WhatsApp support on HillyTrip.
VITE_SUPPORT_WHATSAPP_NUMBER="+919876543210"

# SECURE AUTHENTICATION CONFIGURATION:
# ADMIN_INITIAL_PASSWORD: The initial password to set for default admins on boot/seed. Default: "HillyTripSecureAdmin2026!"
ADMIN_INITIAL_PASSWORD="your-strong-initial-password-here"
# JWT_SECRET: The secret key used to sign and verify secure session tokens. Default: a secure fallback secret.
JWT_SECRET="your-secure-jwt-signing-key-here"

